{
  "type": "function",
  "function":
{
  "name": "mkdir",
  "description": "Creates a new local directory. Fails if the target directory already exists.",
  "parameters": {
    "type": "object",
    "properties": {
      "path": {
        "type": "string",
        "description": "The path of the directory to create (e.g., './output' or '/data/logs')."
      }
    },
    "required": ["path"]
  }
}
}
